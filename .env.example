# OKazCar environment variables
# Copy this file to .env and adjust values

FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Database (default: SQLite in data/okazcar.db)
# DATABASE_URL=sqlite:///data/okazcar.db

# CORS origins (comma-separated)
# CORS_ORIGINS=chrome-extension://*

# Admin dashboard credentials
ADMIN_USERNAME=malik
ADMIN_PASSWORD_HASH=

# External API timeouts (seconds)
SIRET_API_TIMEOUT=5

# Wheel-Size (dimensions pneus : enrichissement en fond)
# Si WHEEL_SIZE_API_KEY est vide, l'enrichissement Wheel-Size est désactivé.
WHEEL_SIZE_API_KEY=
WHEEL_SIZE_BASE_URL=https://api.wheel-size.com/v2
WHEEL_SIZE_DAILY_BUDGET=50

# Logging
LOG_LEVEL=DEBUG

# Extension build (Chrome Web Store)
# Utilisé par `npm run build:ext` (injection dans le bundle). Peut être une base ou un endpoint:
# - https://<service>.onrender.com
# - https://<service>.onrender.com/api
# - https://<service>.onrender.com/api/analyze
# Le build normalise automatiquement vers /api/analyze.
API_URL=
